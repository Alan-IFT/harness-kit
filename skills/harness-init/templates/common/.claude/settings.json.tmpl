{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by harness-kit. Edit hooks/permissions to suit your project. Stop hook auto-runs harness-sync so .harness/agents/ and .harness/skills/ edits flow to .claude/ without you remembering.",
  "_doc_sync_hook": "Stop hook auto-runs harness-sync so a forgotten manual sync never breaks the binding. Command was OS-picked at init time: `pwsh -File .harness/scripts/harness-sync.ps1` on Windows, `bash .harness/scripts/harness-sync.sh` elsewhere. Swap freely if your environment differs (e.g. WSL using bash on Windows, or pwsh installed on Linux).",
  "_guard_hook": "PreToolUse hook auto-runs guard-rm before every Bash tool call. Blocks destructive commands targeting paths outside this project root. Override per-call with HARNESS_ALLOW_OUTSIDE_RM=1. See .harness/rules/75-safety-hook.md to fully disable.",
  "_ambient_hook": "Ambient-stream wiring (two hooks). UserPromptSubmit -> ambient-prompt: runs every user turn, a NO-OP unless .harness/ambient.flag exists; when present it injects an instruction to fold the message into docs/batches/default/BATCH_PLAN.md and drain it. SessionStart -> ambient-reset: deletes the flag at the start of every new session, so ambient mode is session-scoped (no 'off' keyword to remember; invoke /harness-stream with no pool-id to (re-)enter). Commands below are the Windows default; on macOS/Linux without pwsh, change them to: bash .harness/scripts/ambient-prompt.sh and bash .harness/scripts/ambient-reset.sh . The -NoProfile flag is required so the user's $PROFILE does not run per hook. See skills/harness-stream/SKILL.md 'Ambient mode'.",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(poetry:*)",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(pwsh:*)",
      "Bash(bash .harness/scripts/harness-sync.sh:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf /:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{SYNC_COMMAND}}"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{GUARD_COMMAND}}"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File .harness/scripts/ambient-prompt.ps1"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File .harness/scripts/ambient-reset.ps1"
          }
        ]
      }
    ]
  }
}
